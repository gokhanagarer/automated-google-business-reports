# Demo runs WITHOUT any of these set — bundled fixture is used and the
# summarizer falls back to an offline template. Set LIVE=1 + the keys you want
# to switch real services on.

# Required for LIVE mode — Google Places API (New).
# Get one at: https://console.cloud.google.com/apis/library/places.googleapis.com
GOOGLE_PLACES_API_KEY=

# Optional — Groq for LLM-generated summaries and reply drafts.
# Get one at: https://console.groq.com
GROQ_API_KEY=

# Optional — Discord webhook URL for distribution.
DISCORD_WEBHOOK_URL=

# Switch from bundled fixture to live API calls.
LIVE=0
